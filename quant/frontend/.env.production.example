# =================================
# FRONTEND PRODUCTION ENVIRONMENT
# =================================
# Copy this to .env.production.local and fill in your values
# NEVER commit .env.production.local to version control

# =================================
# API CONNECTION
# =================================

# Backend API URL (update after deploying backend to Railway/Render)
NEXT_PUBLIC_API_URL=https://your-backend-url.railway.app
NEXT_PUBLIC_API_VERSION=v1

# =================================
# STRIPE (Frontend)
# =================================

# Stripe Publishable Key (safe for client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key_here

# =================================
# SUPABASE (Optional - for auth)
# =================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =================================
# ANALYTICS
# =================================

# PostHog (Product Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =================================
# MONITORING
# =================================

# Sentry (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# =================================
# FEATURE FLAGS
# =================================

NEXT_PUBLIC_ENABLE_PREMIUM=true
NEXT_PUBLIC_ENABLE_API_ACCESS=true
NEXT_PUBLIC_ENABLE_BACKTESTING=true
NEXT_PUBLIC_ENABLE_OPTIONS_ANALYSIS=true
NEXT_PUBLIC_ENABLE_ML_PREDICTIONS=true

# =================================
# ENVIRONMENT
# =================================

NODE_ENV=production
