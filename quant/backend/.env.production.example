# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your production values
# NEVER commit the actual .env file to version control
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
PROJECT_NAME=Quant Analytics Platform
VERSION=1.0.0
API_V1_STR=/api/v1
ENVIRONMENT=production
DEBUG=false

# =============================================================================
# SECURITY (CRITICAL - CHANGE THESE!)
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-min-32-characters-change-this-in-production

# JWT Token Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# Production PostgreSQL connection
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=quant_prod_user
POSTGRES_PASSWORD=your-strong-database-password-change-this
POSTGRES_DB=quant_prod_db

# Full connection string (auto-generated if not set)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Database connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30

# =============================================================================
# REDIS (Cache & Task Queue)
# =============================================================================
# Main Redis (port 6379) - for Celery and general caching
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ML Redis (port 6380) - for ML result caching
ML_REDIS_HOST=redis-ml
ML_REDIS_PORT=6380
ML_REDIS_URL=redis://${ML_REDIS_HOST}:${ML_REDIS_PORT}/0

# Token Blacklist Redis (separate DB for security)
BLACKLIST_REDIS_DB=1

# =============================================================================
# CELERY (Background Tasks)
# =============================================================================
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Set to your frontend domain(s)
BACKEND_CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com","https://api.yourdomain.com"]

# =============================================================================
# EXTERNAL APIs
# =============================================================================
# Stock data providers
POLYGON_API_KEY=your-polygon-api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Sentry for error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# MLFLOW (ML Experiment Tracking)
# =============================================================================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=https://s3.amazonaws.com
MLFLOW_ARTIFACT_ROOT=s3://your-mlflow-bucket/artifacts

# AWS credentials for MLflow (if using S3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1

# =============================================================================
# EMAIL (for notifications)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Quant Analytics Platform

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_PREMIUM_MULTIPLIER=5

# =============================================================================
# CACHE SETTINGS
# =============================================================================
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=3600
CACHE_ML_RESULTS_TTL=7200

# =============================================================================
# SECURITY HEADERS
# =============================================================================
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_BROWSER_XSS_FILTER=true
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# =============================================================================
# BACKUP & MAINTENANCE
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket

# =============================================================================
# PERFORMANCE
# =============================================================================
# Concurrency limits for ML operations
ML_MAX_CONCURRENT=10
NETWORK_MAX_CONCURRENT=3
EXPORT_MAX_CONCURRENT=5

# Worker configuration
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_KEEPALIVE=5

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_REGISTRATION=true
ENABLE_ML_PREDICTIONS=true
ENABLE_NETWORK_ANALYSIS=true
ENABLE_EXPORT=true
ENABLE_ADMIN_PANEL=true

# =============================================================================
# DOMAIN & SSL
# =============================================================================
DOMAIN=yourdomain.com
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# SSL Certificate paths (for Nginx)
SSL_CERTIFICATE=/etc/letsencrypt/live/${DOMAIN}/fullchain.pem
SSL_CERTIFICATE_KEY=/etc/letsencrypt/live/${DOMAIN}/privkey.pem
