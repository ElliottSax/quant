# =================================
# PRODUCTION ENVIRONMENT VARIABLES
# =================================
# Copy this to .env.production and fill in your production values
# NEVER commit .env.production to version control

# =================================
# CORE SETTINGS
# =================================

# Backend API URL (update after deploying backend)
NEXT_PUBLIC_API_URL=https://your-backend-url.railway.app
NEXT_PUBLIC_API_VERSION=v1

# Frontend URL (update with your Vercel domain)
FRONTEND_URL=https://your-app.vercel.app

# Environment
NODE_ENV=production
ENVIRONMENT=production

# =================================
# DATABASE (Backend - Railway/Render)
# =================================

# PostgreSQL (provided by Railway/Render)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

# Redis (provided by Upstash or Railway)
REDIS_URL=redis://default:password@host:6379

# =================================
# SECURITY (Backend)
# =================================

# CRITICAL: Generate secure keys using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_SECURE_RANDOM_KEY_MIN_32_CHARS
JWT_SECRET_KEY=CHANGE_THIS_TO_DIFFERENT_SECURE_RANDOM_KEY_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =================================
# CORS (Backend)
# =================================

# Update with your Vercel frontend URL
BACKEND_CORS_ORIGINS=["https://your-app.vercel.app"]

# =================================
# STRIPE PAYMENT (Backend & Frontend)
# =================================

# Backend Stripe Keys
STRIPE_SECRET_KEY=sk_live_your_live_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_from_stripe_dashboard

# Frontend Stripe Key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key_here

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_BASIC_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_BASIC_YEARLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE_YEARLY=price_xxxxxxxxxxxxx

# =================================
# SUPABASE (Optional - for Auth)
# =================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Frontend Supabase Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =================================
# MONITORING & ERROR TRACKING
# =================================

# Sentry for error tracking
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend Sentry
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# =================================
# MARKET DATA APIS (Backend)
# =================================

# Free tier API keys
POLYGON_API_KEY=your-polygon-api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
FINNHUB_API_KEY=your-finnhub-key

# =================================
# EMAIL (Backend - for alerts)
# =================================

# Resend (Recommended - 100 emails/day free)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=Quant Platform

# =================================
# ANALYTICS (Frontend)
# =================================

# PostHog (Optional - for product analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Google Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =================================
# FEATURE FLAGS (Frontend)
# =================================

NEXT_PUBLIC_ENABLE_PREMIUM=true
NEXT_PUBLIC_ENABLE_API_ACCESS=true
NEXT_PUBLIC_ENABLE_BACKTESTING=true

# =================================
# RATE LIMITING (Backend)
# =================================

RATE_LIMIT_FREE=100
RATE_LIMIT_BASIC=1000
RATE_LIMIT_PREMIUM=10000
RATE_LIMIT_ENTERPRISE=100000

# =================================
# CELERY (Backend - for background jobs)
# =================================

CELERY_BROKER_URL=redis://default:password@host:6379/0
CELERY_RESULT_BACKEND=redis://default:password@host:6379/0

# =================================
# SECURITY HEADERS
# =================================

TRUST_PROXY_HEADERS=true
TRUSTED_PROXIES=["0.0.0.0/0"]

# =================================
# LOGS & DEBUGGING
# =================================

LOG_LEVEL=INFO
DEBUG=false
RELOAD=false
